				datamodel = "[GetGlobalList('berlin_accept_conf_list')]"
				datamodel_wrap = 6
				flipdirection = yes
				minimumsize = { 0 140 }
				item = {
					flowcontainer = {
						visible = "[Scope.GetCountry.IsValid]"
						tooltip = "[Scope.GetCountry.GetName]"
						margin = { 5 15 }
						minimumsize = { 27 18 }
						small_flag = { datacontext = "[Scope.GetCountry]" }
					}
				}
			}
		}
	}

	widget = {
		parentanchor = hcenter|vcenter
		size = { 900 900 }
		background = {
			using = paper_bg_dark
		}
		default_header_clean_faded = {
			parentanchor = hcenter|top
			blockoverride "text" { raw_text = "Map of Africa" }
			blockoverride "size" { size = { 900 44 } }
		}
		icon = {
			parentanchor = hcenter|vcenter
			texture = "gfx/interface/gui_elements/uncolonizable.dds"
			size = { 3300 1650 }
			position = { -150 -50 }
		}
		button_icon_round = {
				size = { 120 120 }
				position = { 350 750 }
				parentanchor = hcenter
				tooltip = "berlin_conf_law_colonial_tt"
				datacontext = "[GetScriptedGui('berlin_conf_free_colonial_law')]"
				visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
				onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
				onclick = "[GetVariableSystem.Clear('berlin_conf_open')]"
				tooltip = "[ScriptedGui.BuildTooltip( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
				blockoverride "icon" {
					texture = "gfx/interface/icons/law_icons/colonial_exploitation.dds"
				}
			}
		textbox = { #end con
				position = { 140 630 }
				using = fontsize_mega
				fontsize_min = 30
				text = "#bold End Condition#!"
				margin_top = 260
			}
		textbox = {
				size = { 140 630 }
				background = {
					using = fade_right_simple
					margin_left = 10
				}
				text = "Number of Claims Left: #v [GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope.Var('remaining_claims_var').GetValue]#!"
				parentanchor = left
				using = fontsize_large
				position = { 20 45 }
				autoresize = yes
				max_width = 256
			}
		textbox = {
				size = { 140 630 }
				background = {
					using = fade_right_simple
					margin_left = 10
				}
				text = "Locks left: #v [GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope.Var('africa_lock_left_var').GetValue]#!"
				parentanchor = left
				using = fontsize_large
				position = { 20 75 }
				autoresize = yes
				max_width = 256
			}
		textbox = {
				position = { 60 670 }
				using = fontsize_large
				fontsize_min = 30
				text = "#Green #bold - Great Powers 1 to 3 approve the Conference#!#!"
				margin_top = 260
			}
		textbox = {
				position = { 60 700 }
				using = fontsize_large
				fontsize_min = 30
