@panel_width_minus_30 = 510
@panel_width_minus_20 = 520
@panel_width_minus_10 = 530
@panel_width = 540
@panel_width_half = 270
@panel_width_plus_10 = 550
@panel_width_plus_14 = 554
@panel_width_plus_14_half = 277
@panel_width_plus_20 = 560
@panel_width_plus_30 = 570
@panel_width_plus_70 = 610

types berlin_conference_types {
	type berlin_conf_journal_button = container {
		parentanchor = hcenter
		visible = "[EqualTo_string(JournalEntry.GetName, Localize('je_berlin_conference'))]"
		minimumsize = { @panel_width_minus_30 -1 }

		background = {
			alpha = 0.4
			using = entry_bg_fancy_dark
		}

	}

	type claimed_countries_gui = container {
        visible = "[EqualTo_string(JournalEntry.GetName, Localize('je_berlin_conference'))]"
        parentanchor = hcenter

        flowcontainer = {
			parentanchor = hcenter
			direction = vertical
			spacing = 10
			margin = { 10 10 }

			button = {
				using = default_button
				parentanchor = hcenter
				size = { @panel_width_minus_30 50 }
				using = fontsize_large
				text = "Open the #gold Berlin Conference#! view."
				tooltip = "berlin_conf_open_button_tt"
				onclick = "[GetVariableSystem.Set('berlin_conf_open', 'true')]"
				onclick = "[GetVariableSystem.Set('berlin_tab_east', 'true')]"
				onclick = "[GetVariableSystem.Clear('berlin_tab_subsaharan')]"
				onclick = "[GetVariableSystem.Clear('berlin_tab_congo')]"
				onclick = "[GetVariableSystem.Clear('berlin_tab_south')]"
			}
		}


    }

	type berlin_area_tab = widget {
		size = { 160 80 }
		block "tab_position" { parentanchor = hcenter  position = { 0 0 } }

		button = {
			size = { 90% 40% }
			using = default_button_primary
			enabled = no
			block "tab_text" { text = "" }
			using = fontsize_medium
			block "tab_active_visible" { visible = no }
		}

		button = {
			size = { 90% 40% }
			using = default_button
			block "tab_text" { text = "" }
			using = fontsize_medium
			block "tab_inactive_visible" { visible = yes }
			block "tab_onclick" { onclick = "" }
		}
	}

}

window = {
	name = "berlin_conf_gui_trigger"
	parentanchor = hcenter|vcenter
	size = { 1680 960 }
	layer = windows_layer
	filter_mouse = all
	allow_outside = yes
	alwaystransparent = no
	visible = "[GetVariableSystem.Exists('berlin_conf_open')]"
	datacontext = "[GetPlayer]"

	background = {
		using = paper_bg
	}

    widget = {
		size = { 100% 70 }
		position = { 0 -40 }
		parentanchor = hcenter
		using = sidepanel_top_header
        textbox = {
				parentanchor = hcenter
				align = hcenter|nobaseline
				using = fontsize_mega
                fontsize_min = 30
				text = "The Great Partition: Africa at the Berlin Conference"
                margin_top = 70
			}
		
        close_button = {
            parentanchor = right|top
            position = { -5 7 }
            size = { 55 55 }
            onclick = "[GetVariableSystem.Clear('berlin_conf_open')]"
            shortcut = "close_window"
            }
        icon = {
			parentanchor = left|vcenter
			texture = "gfx/interface/icons/event_icons/berlin_conference.dds"
			size = { 100 100 }
			position = { 0 0 }
		}
		icon = {
			parentanchor = left|vcenter
			texture = "gfx/interface/icons/event_icons/scrambleAfrica.dds"
			size = { 120 150 }
			position = { 65 120 }
			}
		icon = {
			parentanchor = left|vcenter
			texture = "gfx/interface/gui_elements/africaDivider.dds"
			size = { 370 200 }
			position = { 15 220 }
			}
		icon = {
			parentanchor = left|vcenter
			texture = "gfx/interface/gui_elements/africaDivider2.dds"
			size = { 154 200 }
			position = { 205 50 }
			}
		icon = {
			parentanchor = left|vcenter
			texture = "gfx/interface/gui_elements/africaDivider.dds"
			size = { 154 200 }
			position = { 205 190 }
			}
		textbox = {
				position = { 232 -37 }
				using = fontsize_medium
				fontsize_min = 30
				text = "#Gold #bold African regions#!#!"
				margin_top = 260
			}
		}
		

	textbox = {
			parentanchor = right
			align = hcenter
			position = { -190 -70 }
			using = fontsize_large
			fontsize_min = 30
			text = "#Gold #bold Rules of the Berlin Conference#!#!"
			margin_top = 260
			textbox = {
				position = { -190 40 }
				using = fontsize_large
				fontsize_min = 30
				text = "- #yellow Nations#! are given claims based on #gold Great#!"
				margin_top = 260
			}
			textbox = {
				position = { -191 60 }
				using = fontsize_large
				fontsize_min = 30
				text = "   #gold Power#! Rank. No further claims are given."
				margin_top = 260
			}

			textbox = {
				position = { -190 90 }
				using = fontsize_large
				fontsize_min = 30
				text = "- One #gold Area#! can only be claimed by 3 #yellow nations#!"
				margin_top = 260
			}
			textbox = {
				position = { -191 110 }
				using = fontsize_large
				fontsize_min = 30
				text = "   at once."
				margin_top = 260
			}

			textbox = {
				position = { -190 140 }
				using = fontsize_large
				fontsize_min = 30
				text = "- At the end of the #gold Conference#! claims on the"
				margin_top = 260
			}
			textbox = {
				position = { -191 160 }
				using = fontsize_large
				fontsize_min = 30
				text = "  #gold African regions#! will be given."
				margin_top = 260
			}
			textbox = {
				position = { -190 190 }
				using = fontsize_large
				fontsize_min = 30
				text = "- #red Great Powers 1 to 3 can lock areas based on"
				margin_top = 260
			}
			textbox = {
				position = { -191 210 }
				using = fontsize_large
				fontsize_min = 30
				text = "   #red rank.#! Locked areas can be claimes only by"
				margin_top = 260
			}
			textbox = {
				position = { -191 230 }
				using = fontsize_large
				fontsize_min = 30
				text = "   other #gold Great Powers#! with rank #bold 1 to 3#!."
				margin_top = 260
			}
			textbox = {
				position = { -190 248 }
				using = fontsize_small
				fontsize_min = 30
				text = "    #yellow (Locks aren't recoverable, they're removed once used.)"
				margin_top = 260
			}
			

		}

	berlin_area_tab = {
		blockoverride "tab_position" { parentanchor = center  position = { -550 -320 } }
		blockoverride "tab_text" { text = "Sub-Saharan Africa" }
		blockoverride "tab_active_visible" {
			visible = "[GetVariableSystem.Exists('berlin_tab_subsaharan')]"
		}
		blockoverride "tab_inactive_visible" {
			visible = "[Not(GetVariableSystem.Exists('berlin_tab_subsaharan'))]"
		}
		blockoverride "tab_onclick" {
			onclick = "[GetVariableSystem.Set('berlin_tab_subsaharan', 'true')]"
			onclick = "[GetVariableSystem.Clear('berlin_tab_congo')]"
			onclick = "[GetVariableSystem.Clear('berlin_tab_south')]"
			onclick = "[GetVariableSystem.Clear('berlin_tab_east')]"
		}
	}

	berlin_area_tab = {
		blockoverride "tab_position" { parentanchor = center  position = { -550 -290 } }
		blockoverride "tab_text" { text = "Congo Area" }
		blockoverride "tab_active_visible" {
			visible = "[GetVariableSystem.Exists('berlin_tab_congo')]"
		}
		blockoverride "tab_inactive_visible" {
			visible = "[Not(GetVariableSystem.Exists('berlin_tab_congo'))]"
		}
		blockoverride "tab_onclick" {
			onclick = "[GetVariableSystem.Set('berlin_tab_congo', 'true')]"
			onclick = "[GetVariableSystem.Clear('berlin_tab_subsaharan')]"
			onclick = "[GetVariableSystem.Clear('berlin_tab_south')]"
			onclick = "[GetVariableSystem.Clear('berlin_tab_east')]"
		}
	}

	berlin_area_tab = {
		blockoverride "tab_position" { parentanchor = center  position = { -550 -350 } }
		blockoverride "tab_text" { text = "South Africa" }
		blockoverride "tab_active_visible" {
			visible = "[GetVariableSystem.Exists('berlin_tab_south')]"
		}
		blockoverride "tab_inactive_visible" {
			visible = "[Not(GetVariableSystem.Exists('berlin_tab_south'))]"
		}
		blockoverride "tab_onclick" {
			onclick = "[GetVariableSystem.Set('berlin_tab_south', 'true')]"
			onclick = "[GetVariableSystem.Clear('berlin_tab_subsaharan')]"
			onclick = "[GetVariableSystem.Clear('berlin_tab_congo')]"
			onclick = "[GetVariableSystem.Clear('berlin_tab_east')]"
		}
	}

	berlin_area_tab = {
		blockoverride "tab_position" { parentanchor = center  position = { -550 -380 } }
		blockoverride "tab_text" { text = "East Africa" }
		blockoverride "tab_active_visible" {
			visible = "[GetVariableSystem.Exists('berlin_tab_east')]"
		}
		blockoverride "tab_inactive_visible" {
			visible = "[Not(GetVariableSystem.Exists('berlin_tab_east'))]"
		}
		blockoverride "tab_onclick" {
			onclick = "[GetVariableSystem.Set('berlin_tab_east', 'true')]"
			onclick = "[GetVariableSystem.Clear('berlin_tab_subsaharan')]"
			onclick = "[GetVariableSystem.Clear('berlin_tab_congo')]"
			onclick = "[GetVariableSystem.Clear('berlin_tab_south')]"
		}
	}


	button_icon_round = {
				size = { 120 120 }
				position = { 650 500 }
				parentanchor = hcenter
				datacontext = "[GetScriptedGui('berlin_conf_enable_treaty_vis')]"
				visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
				onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
				tooltip = "[ScriptedGui.BuildTooltip( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
				blockoverride "icon" {
					texture = "gfx/interface/icons/generic_icons/map_list_cross.dds"
				}
				textbox = {
					parentanchor = hcenter
					align = hcenter|nobaseline
					using = fontsize_large
					fontsize_min = 30
					text = "#bold Africa Diplomatic Treaties:#! #red #bold Disabled #!#!"
					margin_top = -40
				}
			}
			button_icon_round = {
				size = { 120 120 }
				position = { 650 500 }
				parentanchor = hcenter
				datacontext = "[GetScriptedGui('berlin_conf_disable_treaty_vis')]"
				visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
				onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
				tooltip = "[ScriptedGui.BuildTooltip( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
				blockoverride "icon" {
					texture = "gfx/interface/icons/generic_icons/mandate.dds"
				}
				textbox = {
					parentanchor = hcenter
					align = hcenter|nobaseline
					using = fontsize_large
					fontsize_min = 30
					text = "#bold Africa Diplomatic Treaties:#! #green #bold Enabled #!#!"
					margin_top = -40
				}
				textbox = {
					parentanchor = hcenter
					align = hcenter|nobaseline
					using = fontsize_large
					fontsize_min = 30
					text = "(Allows claim negotiation treaties on you.)"
					margin_top = 260
				}
			}


	flowcontainer = {
		position = { -735 250 }
		parentanchor = hcenter
		alwaystransparent = yes
		visible = "[GetVariableSystem.Exists('berlin_tab_subsaharan')]"
		background = { using = entry_bg_fancy_dark }
		direction = vertical
		flowcontainer = {
			direction = horizontal
			spacing = 4
			alwaystransparent = yes
			button = {
				name = "berlin_claim_btn_west_africa"
				using = default_button_primary_action
				size = { 100 35 }
				minimumsize = { 182 35 }
				maximumsize = { 182 45 }
				text = "West Africa"
				datacontext = "[GetScriptedGui('berlin_conf_claim_west_africa')]"
				visible = "[EqualTo_string(JournalEntry.GetName, Localize('je_berlin_conference'))]"
				enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
				tooltip = "[ScriptedGui.BuildTooltip( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
				onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
				button_icon_round = {
					size = { 35 35 }
					parentanchor = right
					datacontext = "[GetScriptedGui('berlin_conf_lock_west_africa')]"
					visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
					enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
					tooltip = "[ScriptedGui.BuildTooltip( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
					onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
					blockoverride "icon" { texture = "gfx/interface/icons/generic_icons/mandate.dds" }
				}
				button_icon_round = {
					size = { 35 35 }
					parentanchor = right
					datacontext = "[GetScriptedGui('berlin_conf_unlock_west_africa')]"
					visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
					enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
					tooltip = "[ScriptedGui.BuildTooltip( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
					onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( GetMetaPlayer.GetPlayedOrObservedCountry.MakeScope ).End )]"
					blockoverride "icon" { texture = "gfx/interface/icons/generic_icons/map_list_cross.dds" }
				}
			
			}
			
		}
		dynamicgridbox = {
			parentanchor = hcenter
			datamodel = "[GetGlobalList('west_africa_claimed_countries_list')]"
			datamodel_wrap = 3
			flipdirection = yes
			minimumsize = { 0 58 }
			item = {
				flowcontainer = {
					visible = "[Scope.GetCountry.IsValid]"
					margin = { 5 20 }
					minimumsize = { 27 18 }
					small_flag = { datacontext = "[Scope.GetCountry]" }
				}
			}
		}
	}
