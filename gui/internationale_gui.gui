window = {
	name = "internationale_gui_trigger"
	parentanchor = hcenter|vcenter
	size = { 1280 960 }
	layer = windows_layer
	filter_mouse = all
	allow_outside = yes
	alwaystransparent = no

	visible = "[GetVariableSystem.Exists('internationale_open')]"
	datacontext = "[GetPlayer]"

	background = {
		using = paper_bg
	}


	vbox = {
		layoutpolicy_horizontal = expanding
		layoutpolicy_vertical = expanding

		### HEADER
		hbox = {
			layoutpolicy_horizontal = expanding
			minimumsize = { 0 54 }

			background = {
				using = default_header_bg
			}

			margin = { 14 0 }
			spacing = 10

			icon = {
				size = { 28 28 }
				parentanchor = vcenter
				texture = "gfx/interface/icons/generic_icons/identity_overlay.dds"
				color = { 0.88 0.78 0.32 1 }
			}

			textbox = {
				layoutpolicy_horizontal = expanding
				size = { 0 54 }
				text = "intl_parliament_title"
				using = fontsize_xxl
				align = left|nobaseline
				parentanchor = vcenter
			}
		}

		### SUBTITLE
		widget = {
			layoutpolicy_horizontal = expanding
			size = { 0 36 }

			background = {
				using = dark_area
				alpha = 0.4
			}

			textbox = {
				size = { 100% 100% }
				text = "intl_parliament_desc"
				using = fontsize_medium
				align = hcenter|nobaseline
				parentanchor = center
				alpha = 0.8
			}
		}

		divider_clean = {
			layoutpolicy_horizontal = expanding
		}

		### SPACER
		widget = { size = { 0 8 } }

		### PARLIAMENT GRAPH
		widget = {
			layoutpolicy_horizontal = expanding
			size = { 0 290 }
			background = {
						texture = "gfx/interface/backgrounds/bg_internationale.dds"
						size = { 90% 90% }
						alpha = 0.2
						margin_left = -10
						margin_right = -10
					}
			using = tooltip_below
			tooltip = "intl_parliament_tooltip"

			margin = { 10 5 }

			container = {
					visible = "[GetPlayer.MakeScope.Var('ISideologyleader_scope_gui').IsSet]"
					datacontext = "[GetPlayer.MakeScope.Var('ideologyleader_scope_gui').GetCharacter]"
					parentanchor = left
					size = { 90% 90% }
					position = { 25 -50 }
					flowcontainer = {
						
						direction = vertical
						character_portrait_front_vs_left = {
							position = { 0 0 }
							parentanchor = hcenter
							blockoverride "highlight" {}
							blockoverride "commander_order_icon" {}
						}
						
					}
				}
			hbox = {
				layoutpolicy_horizontal = expanding
				size = { 100% 280 }

				widget = {
					size = { 0 1 }
					layoutpolicy_horizontal = expanding
				}

				widget = {
					size = { 200 280 }
					intl_parliament_visual_anarchist = {}
					intl_parliament_visual_mutualist = {}
					intl_parliament_visual_syndicalist = {}
					intl_parliament_visual_blanquist = {}
					intl_parliament_visual_marxist = {}
				}

				widget = {
					size = { 0 1 }
					layoutpolicy_horizontal = expanding
				}

				### CURRENT LAW CONTAINER
				widget = {
					size = { 410 280 }
					vbox = {
						layoutpolicy_horizontal = expanding
						spacing = 4
						position = { -6 -6 }
						expand = {}
						### ROW 1: governance + distribution_of_power
						hbox = {
							spacing = 4
							### governance
							widget = {
								size = { 195 65 }
								button = { size = { 195 65 } using = default_button visible = "[GetGlobalVariable('intl_law_anarchist_council_republic').IsSet]" tooltip = "[GetLawType('law_anarchist_council_republic').GetName]" hbox = { layoutpolicy_horizontal = expanding spacing = 5 margin = { 8 0 } icon = { size = { 40 40 } parentanchor = left|top texture = "gfx/interface/icons/law_icons/anarchist/anarchist_council_republic.dds" } vbox = { layoutpolicy_horizontal = expanding layoutpolicy_vertical = expanding expand = {} textbox = { layoutpolicy_horizontal = expanding align = nobaseline minimumsize = { -1 20 } using = fontsize_small text = "lawgroup_governance_principles" } textbox = { layoutpolicy_horizontal = expanding minimumsize = { -1 20 } align = nobaseline fontsize_min = 10 using = fontsize_xsmall text = "law_anarchist_council_republic" } expand = {} } } }
								button = { size = { 195 65 } using = default_button visible = "[GetGlobalVariable('intl_law_marxist_council_republic').IsSet]" tooltip = "[GetLawType('law_marxist_council_republic').GetName]" hbox = { layoutpolicy_horizontal = expanding spacing = 5 margin = { 8 0 } icon = { size = { 40 40 } parentanchor = left|top texture = "gfx/interface/icons/law_icons/marxist/marxist_council_republic.png" } vbox = { layoutpolicy_horizontal = expanding layoutpolicy_vertical = expanding expand = {} textbox = { layoutpolicy_horizontal = expanding align = nobaseline minimumsize = { -1 20 } using = fontsize_small text = "lawgroup_governance_principles" } textbox = { layoutpolicy_horizontal = expanding minimumsize = { -1 20 } align = nobaseline fontsize_min = 10 using = fontsize_xsmall text = "law_marxist_council_republic" } expand = {} } } }
								button = { size = { 195 65 } using = default_button visible = "[GetGlobalVariable('intl_law_mutualist_council_republic').IsSet]" tooltip = "[GetLawType('law_mutualist_council_republic').GetName]" hbox = { layoutpolicy_horizontal = expanding spacing = 5 margin = { 8 0 } icon = { size = { 40 40 } parentanchor = left|top texture = "gfx/interface/icons/law_icons/mutualist/mutualist_council_republic.dds" } vbox = { layoutpolicy_horizontal = expanding layoutpolicy_vertical = expanding expand = {} textbox = { layoutpolicy_horizontal = expanding align = nobaseline minimumsize = { -1 20 } using = fontsize_small text = "lawgroup_governance_principles" } textbox = { layoutpolicy_horizontal = expanding minimumsize = { -1 20 } align = nobaseline fontsize_min = 10 using = fontsize_xsmall text = "law_mutualist_council_republic" } expand = {} } } }
								button = { size = { 195 65 } using = default_button visible = "[GetGlobalVariable('intl_law_syndicalist_council_republic').IsSet]" tooltip = "[GetLawType('law_syndicalist_council_republic').GetName]" hbox = { layoutpolicy_horizontal = expanding spacing = 5 margin = { 8 0 } icon = { size = { 40 40 } parentanchor = left|top texture = "gfx/interface/icons/law_icons/syndacalism/syndicalism_council_republic.dds" } vbox = { layoutpolicy_horizontal = expanding layoutpolicy_vertical = expanding expand = {} textbox = { layoutpolicy_horizontal = expanding align = nobaseline minimumsize = { -1 20 } using = fontsize_small text = "lawgroup_governance_principles" } textbox = { layoutpolicy_horizontal = expanding minimumsize = { -1 20 } align = nobaseline fontsize_min = 10 using = fontsize_xsmall text = "law_syndicalist_council_republic" } expand = {} } } }
								button = { size = { 195 65 } using = default_button visible = "[GetGlobalVariable('intl_law_blanquist_presidential_republic').IsSet]" tooltip = "[GetLawType('law_blanquist_presidential_republic').GetName]" hbox = { layoutpolicy_horizontal = expanding spacing = 5 margin = { 8 0 } icon = { size = { 40 40 } parentanchor = left|top texture = "gfx/interface/icons/law_icons/blanquist/blanquist_presidential_republic.dds" } vbox = { layoutpolicy_horizontal = expanding layoutpolicy_vertical = expanding expand = {} textbox = { layoutpolicy_horizontal = expanding align = nobaseline minimumsize = { -1 20 } using = fontsize_small text = "lawgroup_governance_principles" } textbox = { layoutpolicy_horizontal = expanding minimumsize = { -1 20 } align = nobaseline fontsize_min = 10 using = fontsize_xsmall text = "law_blanquist_presidential_republic" } expand = {} } } }
							}
							### distribution_of_power
							widget = {
								size = { 195 65 }
								button = { size = { 195 65 } using = default_button visible = "[GetGlobalVariable('intl_law_marxist_one_party_state').IsSet]" tooltip = "[GetLawType('law_marxist_one_party_state').GetName]" hbox = { layoutpolicy_horizontal = expanding spacing = 5 margin = { 8 0 } icon = { size = { 40 40 } parentanchor = left|top texture = "gfx/interface/icons/law_icons/marxist/marxist_one_party_state.dds" } vbox = { layoutpolicy_horizontal = expanding layoutpolicy_vertical = expanding expand = {} textbox = { layoutpolicy_horizontal = expanding align = nobaseline minimumsize = { -1 20 } using = fontsize_small text = "lawgroup_distribution_of_power" } textbox = { layoutpolicy_horizontal = expanding minimumsize = { -1 20 } align = nobaseline fontsize_min = 10 using = fontsize_xsmall text = "law_marxist_one_party_state" } expand = {} } } }
							}
						}
						### ROW 2: economic_system + bureaucracy
						hbox = {
							spacing = 4
							### economic_system
							widget = {
								size = { 195 65 }
								button = { size = { 195 65 } using = default_button visible = "[GetGlobalVariable('intl_law_marxist_economy').IsSet]" tooltip = "[GetLawType('law_marxist_economy').GetName]" hbox = { layoutpolicy_horizontal = expanding spacing = 5 margin = { 8 0 } icon = { size = { 40 40 } parentanchor = left|top texture = "gfx/interface/icons/law_icons/marxist/marxist_economy.dds" } vbox = { layoutpolicy_horizontal = expanding layoutpolicy_vertical = expanding expand = {} textbox = { layoutpolicy_horizontal = expanding align = nobaseline minimumsize = { -1 20 } using = fontsize_small text = "lawgroup_economic_system" } textbox = { layoutpolicy_horizontal = expanding minimumsize = { -1 20 } align = nobaseline fontsize_min = 10 using = fontsize_xsmall text = "law_marxist_economy" } expand = {} } } }
								button = { size = { 195 65 } using = default_button visible = "[GetGlobalVariable('intl_law_mutualist_economy').IsSet]" tooltip = "[GetLawType('law_mutualist_economy').GetName]" hbox = { layoutpolicy_horizontal = expanding spacing = 5 margin = { 8 0 } icon = { size = { 40 40 } parentanchor = left|top texture = "gfx/interface/icons/law_icons/mutualist/mutualist_economy.dds" } vbox = { layoutpolicy_horizontal = expanding layoutpolicy_vertical = expanding expand = {} textbox = { layoutpolicy_horizontal = expanding align = nobaseline minimumsize = { -1 20 } using = fontsize_small text = "lawgroup_economic_system" } textbox = { layoutpolicy_horizontal = expanding minimumsize = { -1 20 } align = nobaseline fontsize_min = 10 using = fontsize_xsmall text = "law_mutualist_economy" } expand = {} } } }
								button = { size = { 195 65 } using = default_button visible = "[GetGlobalVariable('intl_law_anarchist_economy').IsSet]" tooltip = "[GetLawType('law_anarchist_economy').GetName]" hbox = { layoutpolicy_horizontal = expanding spacing = 5 margin = { 8 0 } icon = { size = { 40 40 } parentanchor = left|top texture = "gfx/interface/icons/law_icons/anarchist/anarchist_economy.dds" } vbox = { layoutpolicy_horizontal = expanding layoutpolicy_vertical = expanding expand = {} textbox = { layoutpolicy_horizontal = expanding align = nobaseline minimumsize = { -1 20 } using = fontsize_small text = "lawgroup_economic_system" } textbox = { layoutpolicy_horizontal = expanding minimumsize = { -1 20 } align = nobaseline fontsize_min = 10 using = fontsize_xsmall text = "law_anarchist_economy" } expand = {} } } }
								button = { size = { 195 65 } using = default_button visible = "[GetGlobalVariable('intl_law_syndicalist_economy').IsSet]" tooltip = "[GetLawType('law_syndicalist_economy').GetName]" hbox = { layoutpolicy_horizontal = expanding spacing = 5 margin = { 8 0 } icon = { size = { 40 40 } parentanchor = left|top texture = "gfx/interface/icons/law_icons/syndacalism/syndacalist_economy.dds" } vbox = { layoutpolicy_horizontal = expanding layoutpolicy_vertical = expanding expand = {} textbox = { layoutpolicy_horizontal = expanding align = nobaseline minimumsize = { -1 20 } using = fontsize_small text = "lawgroup_economic_system" } textbox = { layoutpolicy_horizontal = expanding minimumsize = { -1 20 } align = nobaseline fontsize_min = 10 using = fontsize_xsmall text = "law_syndicalist_economy" } expand = {} } } }
								button = { size = { 195 65 } using = default_button visible = "[GetGlobalVariable('intl_law_blanquist_economy').IsSet]" tooltip = "[GetLawType('law_blanquist_economy').GetName]" hbox = { layoutpolicy_horizontal = expanding spacing = 5 margin = { 8 0 } icon = { size = { 40 40 } parentanchor = left|top texture = "gfx/interface/icons/law_icons/blanquist/blanquist_economy.dds" } vbox = { layoutpolicy_horizontal = expanding layoutpolicy_vertical = expanding expand = {} textbox = { layoutpolicy_horizontal = expanding align = nobaseline minimumsize = { -1 20 } using = fontsize_small text = "lawgroup_economic_system" } textbox = { layoutpolicy_horizontal = expanding minimumsize = { -1 20 } align = nobaseline fontsize_min = 10 using = fontsize_xsmall text = "law_blanquist_economy" } expand = {} } } }
							}
							### bureaucracy
							widget = {
								size = { 195 65 }
								button = { size = { 195 65 } using = default_button visible = "[GetGlobalVariable('intl_law_marxist_bureaucracy').IsSet]" tooltip = "[GetLawType('law_marxist_bureaucracy').GetName]" hbox = { layoutpolicy_horizontal = expanding spacing = 5 margin = { 8 0 } icon = { size = { 40 40 } parentanchor = left|top texture = "gfx/interface/icons/law_icons/marxist/marxist_bureocracy.dds" } vbox = { layoutpolicy_horizontal = expanding layoutpolicy_vertical = expanding expand = {} textbox = { layoutpolicy_horizontal = expanding align = nobaseline minimumsize = { -1 20 } using = fontsize_small text = "lawgroup_bureaucracy" } textbox = { layoutpolicy_horizontal = expanding minimumsize = { -1 20 } align = nobaseline fontsize_min = 10 using = fontsize_xsmall text = "law_marxist_bureaucracy" } expand = {} } } }
							}
						}
						### ROW 3: army_model (centered)
						hbox = {
							parentanchor = left
							### army_model
							widget = {
								size = { 195 65 }
								button = { size = { 195 65 } using = default_button visible = "[GetGlobalVariable('intl_law_marxist_army').IsSet]" tooltip = "[GetLawType('law_marxist_army').GetName]" hbox = { layoutpolicy_horizontal = expanding spacing = 5 margin = { 8 0 } icon = { size = { 40 40 } parentanchor = left|top texture = "gfx/interface/icons/law_icons/marxist/marxist_army.dds" } vbox = { layoutpolicy_horizontal = expanding layoutpolicy_vertical = expanding expand = {} textbox = { layoutpolicy_horizontal = expanding align = nobaseline minimumsize = { -1 20 } using = fontsize_small text = "lawgroup_army_model" } textbox = { layoutpolicy_horizontal = expanding minimumsize = { -1 20 } align = nobaseline fontsize_min = 10 using = fontsize_xsmall text = "law_marxist_army" } expand = {} } } }
								button = { size = { 195 65 } using = default_button visible = "[GetGlobalVariable('intl_law_mutualist_armed_neutrality').IsSet]" tooltip = "[GetLawType('law_mutualist_armed_neutrality').GetName]" hbox = { layoutpolicy_horizontal = expanding spacing = 5 margin = { 8 0 } icon = { size = { 40 40 } parentanchor = left|top texture = "gfx/interface/icons/law_icons/mutualist/mutualist_armed_neutrality.dds" } vbox = { layoutpolicy_horizontal = expanding layoutpolicy_vertical = expanding expand = {} textbox = { layoutpolicy_horizontal = expanding align = nobaseline minimumsize = { -1 20 } using = fontsize_small text = "lawgroup_army_model" } textbox = { layoutpolicy_horizontal = expanding minimumsize = { -1 20 } align = nobaseline fontsize_min = 10 using = fontsize_xsmall text = "law_mutualist_armed_neutrality" } expand = {} } } }
							}
						}
						expand = {}
					}
				}
			}

			### CURRENT MOTION BUTTON â€” overlaid at bottom center of parliament
			button_standard = {
				size = { 260 32 }
				parentanchor = hcenter|bottom
				position = { 0 -6 }
				text = "intl_tab_current_motion"
				using = fontsize_medium
				onclick = "[GetVariableSystem.Clear('intl_tab_anarchist')]"
				onclick = "[GetVariableSystem.Clear('intl_tab_mutualist')]"
				onclick = "[GetVariableSystem.Clear('intl_tab_syndicalist')]"
				onclick = "[GetVariableSystem.Clear('intl_tab_blanquist')]"
				onclick = "[GetVariableSystem.Clear('intl_tab_marxist')]"
			}

		}

		### SPACER
		widget = { size = { 0 6 } }

		### DELEGATES LABEL
		widget = {
			layoutpolicy_horizontal = expanding
			size = { 0 26 }

			background = {
				using = dark_area
				alpha = 0.1
			}

			textbox = {
				size = { 100% 100% }
				text = "intl_delegates_label"
				using = fontsize_small
				align = hcenter|nobaseline
				parentanchor = center
				alpha = 0.45
			}
		}

		### FACTION TAB BUTTONS
		hbox = {
			layoutpolicy_horizontal = expanding
			size = { 0 30 }
			spacing = 2
			margin = { 8 0 }

			intl_tab_button = {
				blockoverride "tab_color" {
					color = { 0.15 0.15 0.15 1 }
				}
				blockoverride "tab_text" {
					text = "intl_faction_anarchist"
				}
				blockoverride "tab_active_visible" {
					visible = "[GetVariableSystem.Exists('intl_tab_anarchist')]"
				}
				blockoverride "tab_inactive_visible" {
					visible = "[Not(GetVariableSystem.Exists('intl_tab_anarchist'))]"
				}
				blockoverride "tab_onclick_set" {
					onclick = "[GetVariableSystem.Clear('intl_tab_mutualist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_syndicalist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_blanquist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_marxist')]"
					onclick = "[GetVariableSystem.Set('intl_tab_anarchist', 'true')]"
				}
				blockoverride "tab_onclick_clear" {
					onclick = "[GetVariableSystem.Clear('intl_tab_anarchist')]"
				}
			}

			intl_tab_button = {
				blockoverride "tab_color" {
					color = { 0.9 0.6 0.1 1 }
				}
				blockoverride "tab_text" {
					text = "intl_faction_mutualist"
				}
				blockoverride "tab_active_visible" {
					visible = "[GetVariableSystem.Exists('intl_tab_mutualist')]"
				}
				blockoverride "tab_inactive_visible" {
					visible = "[Not(GetVariableSystem.Exists('intl_tab_mutualist'))]"
				}
				blockoverride "tab_onclick_set" {
					onclick = "[GetVariableSystem.Clear('intl_tab_anarchist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_syndicalist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_blanquist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_marxist')]"
					onclick = "[GetVariableSystem.Set('intl_tab_mutualist', 'true')]"
				}
				blockoverride "tab_onclick_clear" {
					onclick = "[GetVariableSystem.Clear('intl_tab_mutualist')]"
				}
			}

			intl_tab_button = {
				blockoverride "tab_color" {
					color = { 0.8 0.15 0.15 1 }
				}
				blockoverride "tab_text" {
					text = "intl_faction_syndicalist"
				}
				blockoverride "tab_active_visible" {
					visible = "[GetVariableSystem.Exists('intl_tab_syndicalist')]"
				}
				blockoverride "tab_inactive_visible" {
					visible = "[Not(GetVariableSystem.Exists('intl_tab_syndicalist'))]"
				}
				blockoverride "tab_onclick_set" {
					onclick = "[GetVariableSystem.Clear('intl_tab_anarchist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_mutualist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_blanquist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_marxist')]"
					onclick = "[GetVariableSystem.Set('intl_tab_syndicalist', 'true')]"
				}
				blockoverride "tab_onclick_clear" {
					onclick = "[GetVariableSystem.Clear('intl_tab_syndicalist')]"
				}
			}

			intl_tab_button = {
				blockoverride "tab_color" {
					color = { 0.2 0.3 0.7 1 }
				}
				blockoverride "tab_text" {
					text = "intl_faction_blanquist"
				}
				blockoverride "tab_active_visible" {
					visible = "[GetVariableSystem.Exists('intl_tab_blanquist')]"
				}
				blockoverride "tab_inactive_visible" {
					visible = "[Not(GetVariableSystem.Exists('intl_tab_blanquist'))]"
				}
				blockoverride "tab_onclick_set" {
					onclick = "[GetVariableSystem.Clear('intl_tab_anarchist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_mutualist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_syndicalist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_marxist')]"
					onclick = "[GetVariableSystem.Set('intl_tab_blanquist', 'true')]"
				}
				blockoverride "tab_onclick_clear" {
					onclick = "[GetVariableSystem.Clear('intl_tab_blanquist')]"
				}
			}

			intl_tab_button = {
				blockoverride "tab_color" {
					color = { 0.55 0.2 0.6 1 }
				}
				blockoverride "tab_text" {
					text = "intl_faction_marxist"
				}
				blockoverride "tab_active_visible" {
					visible = "[GetVariableSystem.Exists('intl_tab_marxist')]"
				}
				blockoverride "tab_inactive_visible" {
					visible = "[Not(GetVariableSystem.Exists('intl_tab_marxist'))]"
				}
				blockoverride "tab_onclick_set" {
					onclick = "[GetVariableSystem.Clear('intl_tab_anarchist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_mutualist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_syndicalist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_blanquist')]"
					onclick = "[GetVariableSystem.Set('intl_tab_marxist', 'true')]"
				}
				blockoverride "tab_onclick_clear" {
					onclick = "[GetVariableSystem.Clear('intl_tab_marxist')]"
				}
			}
		}

		divider_clean = {
			layoutpolicy_horizontal = expanding
		}

		### CHARACTER CARDS ROW
		hbox = {
			layoutpolicy_horizontal = expanding
			size = { 0 118 }
			spacing = 2
			margin = { 8 0 }

			intl_faction_card = {
				blockoverride "card_color" {
					color = { 0.15 0.15 0.15 1 }
				}
				blockoverride "card_portrait" {
					character_portrait_small2 = {
						position = { 0 35 }
						parentanchor = vcenter
						datacontext = "[GetPlayer.MakeScope.Var('bakunin_scope_gui').GetCharacter]"
						blockoverride "show_hat" {}
						blockoverride "highlight" {}
					}
				}

				blockoverride "card_delegate" { text = "intl_delegate_anarchist_name" }
				blockoverride "card_role" { text = "intl_delegate_anarchist_role" }
				blockoverride "card_active_visible" {
					visible = "[GetVariableSystem.Exists('intl_tab_anarchist')]"
				}
				blockoverride "card_inactive_visible" {
					visible = "[Not(GetVariableSystem.Exists('intl_tab_anarchist'))]"
				}
				blockoverride "card_onclick_set" {
					onclick = "[GetVariableSystem.Clear('intl_tab_mutualist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_syndicalist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_blanquist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_marxist')]"
					onclick = "[GetVariableSystem.Set('intl_tab_anarchist', 'true')]"
				}
				blockoverride "card_onclick_clear" {
					onclick = "[GetVariableSystem.Clear('intl_tab_anarchist')]"
				}
			}

			intl_faction_card = {
				parentanchor = center|left
				blockoverride "card_color" {
					color = { 0.9 0.6 0.1 1 }
				}
				blockoverride "card_portrait" {
					character_portrait_small2 = {
						position = { 0 35 }
						parentanchor = vcenter
						datacontext = "[GetPlayer.MakeScope.Var('proudhon_scope_gui').GetCharacter]"
						blockoverride "show_hat" {}
						blockoverride "highlight" {}
					}
				}

				blockoverride "card_delegate" { text = "intl_delegate_mutualist_name" }
				blockoverride "card_role" { text = "intl_delegate_mutualist_role" }
				blockoverride "card_active_visible" {
					visible = "[GetVariableSystem.Exists('intl_tab_mutualist')]"
				}
				blockoverride "card_inactive_visible" {
					visible = "[Not(GetVariableSystem.Exists('intl_tab_mutualist'))]"
				}
				blockoverride "card_onclick_set" {
					onclick = "[GetVariableSystem.Clear('intl_tab_anarchist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_syndicalist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_blanquist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_marxist')]"
					onclick = "[GetVariableSystem.Set('intl_tab_mutualist', 'true')]"
				}
				blockoverride "card_onclick_clear" {
					onclick = "[GetVariableSystem.Clear('intl_tab_mutualist')]"
