			}

			intl_faction_card = {
				blockoverride "card_color" {
					color = { 0.8 0.15 0.15 1 }
				}
				blockoverride "card_portrait" {
					character_portrait_small2 = {
						position = { 0 35 }
						parentanchor = vcenter
						datacontext = "[GetPlayer.MakeScope.Var('bel_de_paepe_scope_gui').GetCharacter]"
						blockoverride "show_hat" {}
						blockoverride "highlight" {}
					}
				}

				blockoverride "card_delegate" { text = "intl_delegate_syndicalist_name" }
				blockoverride "card_role" { text = "intl_delegate_syndicalist_role" }
				blockoverride "card_active_visible" {
					visible = "[GetVariableSystem.Exists('intl_tab_syndicalist')]"
				}
				blockoverride "card_inactive_visible" {
					visible = "[Not(GetVariableSystem.Exists('intl_tab_syndicalist'))]"
				}
				blockoverride "card_onclick_set" {
					onclick = "[GetVariableSystem.Clear('intl_tab_anarchist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_mutualist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_blanquist')]"
					onclick = "[GetVariableSystem.Clear('intl_tab_marxist')]"
					onclick = "[GetVariableSystem.Set('intl_tab_syndicalist', 'true')]"
				}
				blockoverride "card_onclick_clear" {
					onclick = "[GetVariableSystem.Clear('intl_tab_syndicalist')]"
				}
