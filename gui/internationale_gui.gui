							button = { size = { 195 65 } using = default_button tooltip = "[GetLawType('law_marxist_army').GetName]" hbox = { layoutpolicy_horizontal = expanding spacing = 5 margin = { 8 0 } icon = { size = { 40 40 } parentanchor = left|top texture = "gfx/interface/icons/law_icons/marxist/marxist_army.dds" } vbox = { layoutpolicy_horizontal = expanding layoutpolicy_vertical = expanding expand = {} textbox = { layoutpolicy_horizontal = expanding align = nobaseline minimumsize = { -1 20 } using = fontsize_small text = "lawgroup_army_model" } textbox = { layoutpolicy_horizontal = expanding minimumsize = { -1 20 } align = nobaseline fontsize_min = 10 using = fontsize_xsmall text = "law_marxist_army" } expand = {} } } }
						}
					blockoverride "detail_portrait" {
							widget = {
								size = { 217 320 }
								parentanchor = vcenter
								datacontext = "[GetPlayer.MakeScope.Var('karl_marx_scope_gui').GetCharacter]"
								tooltipwidget = { FancyTooltip_Character = {} }
								character_portrait_large_torso = {
									position = { 0 0 }
									parentanchor = hcenter
									blockoverride "show_hat" {}
									blockoverride "tooltip" {}
									blockoverride "portrait_icons" {}
									blockoverride "portrait_button" {}
								}
								default_header_clean_faded = {
									size = { 217 40 }
									position = { 0 276 }
									blockoverride "text" {}
									parentanchor = hcenter
									textbox = {
										text = "[Character.GetFullName]"
										parentanchor = vcenter|hcenter
										position = { 0 -2 }
										autoresize = yes
										max_width = 217
										using = fontsize_large
										alwaystransparent = yes
									}
								}
							}
						}
					}
				}

			}
		}

		divider_clean = {
			layoutpolicy_horizontal = expanding
		}

		### FOOTER QUOTE
		widget = {
			layoutpolicy_horizontal = expanding
			size = { 0 34 }

			background = {
				using = dark_area
				alpha = 0.15
			}

			textbox = {
				size = { 100% 100% }
				text = "intl_footer_text"
				using = fontsize_small
				align = hcenter|nobaseline
				parentanchor = center
				alpha = 0.6
			}
		}
	}

	### VOTE BUTTONS â€” rendered after vbox so they sit on top of portrait
	flowcontainer = {
		visible = "[And(Not(Or(Or(Or(Or(GetVariableSystem.Exists('intl_tab_anarchist'), GetVariableSystem.Exists('intl_tab_mutualist')), GetVariableSystem.Exists('intl_tab_syndicalist')), GetVariableSystem.Exists('intl_tab_blanquist')), GetVariableSystem.Exists('intl_tab_marxist'))), GetGlobalVariable('intl_vote_active').IsSet)]"
		direction = vertical
		position = { 242 660 }
		background = { using = dark_area alpha = 0.6 }
		background = { using = simple_frame }
		button_standard = {
			size = { 195 36 }
			text = "intl_vote_keep_button"
			datacontext = "[GetScriptedGui('intl_cast_vote_current_sgui')]"
			enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
			tooltip = "[ScriptedGui.BuildTooltip( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
			onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
		}
		dynamicgridbox = {
			parentanchor = hcenter
			datamodel = "[GetGlobalList('intl_vote_keep_list')]"
			datamodel_wrap = 3
			flipdirection = yes
			item = {
				flowcontainer = {
					visible = "[Scope.GetCountry.IsValid]"
					margin = { 5 5 }
					minimumsize = { 27 18 }
					small_flag = { datacontext = "[Scope.GetCountry]" }
				}
			}
		}
	}

	flowcontainer = {
		visible = "[And(Not(Or(Or(Or(Or(GetVariableSystem.Exists('intl_tab_anarchist'), GetVariableSystem.Exists('intl_tab_mutualist')), GetVariableSystem.Exists('intl_tab_syndicalist')), GetVariableSystem.Exists('intl_tab_blanquist')), GetVariableSystem.Exists('intl_tab_marxist'))), GetGlobalVariable('intl_vote_active').IsSet)]"
		direction = vertical
		position = { 878 660 }
		background = { using = dark_area alpha = 0.6 }
		background = { using = dark_area }
		background = { using = simple_frame }
		button_standard = {
			size = { 195 36 }
			text = "intl_vote_support_button"
			datacontext = "[GetScriptedGui('intl_cast_vote_proposed_sgui')]"
			enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
			tooltip = "[ScriptedGui.BuildTooltip( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
			onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
		}
		dynamicgridbox = {
			parentanchor = hcenter
			datamodel = "[GetGlobalList('intl_vote_proposed_list')]"
			datamodel_wrap = 3
			flipdirection = yes
			item = {
				flowcontainer = {
					visible = "[Scope.GetCountry.IsValid]"
					margin = { 5 5 }
					minimumsize = { 27 18 }
					small_flag = { datacontext = "[Scope.GetCountry]" }
				}
			}
		}
	}

	### VOTE PRESTIGE BAR
	double_direction_progressbar = {
		visible = "[And(Not(Or(Or(Or(Or(GetVariableSystem.Exists('intl_tab_anarchist'), GetVariableSystem.Exists('intl_tab_mutualist')), GetVariableSystem.Exists('intl_tab_syndicalist')), GetVariableSystem.Exists('intl_tab_blanquist')), GetVariableSystem.Exists('intl_tab_marxist'))), GetGlobalVariable('intl_vote_active').IsSet)]"
		size = { 410 30 }
		position = { 15 750 }
		alpha = 0.70
		parentanchor = top|hcenter
		blockoverride "negative_min_max_values" {
			min = "[GetGlobalVariable('intl_vote_prestige_total_neg').GetValue]"
			max = 0
		}
		blockoverride "value_left" {
			value = "[GetGlobalVariable('intl_vote_prestige_current_neg').GetValue]"
		}
		blockoverride "positive_min_max_values" {
			min = 0
			max = "[GetGlobalVariable('intl_vote_prestige_total').GetValue]"
		}
		blockoverride "value_right" {
			value = "[GetGlobalVariable('intl_vote_prestige_proposed').GetValue]"
		}
	}

	### VOTE TIMER BAR
	default_progressbar_horizontal = {
		visible = "[And(Not(Or(Or(Or(Or(GetVariableSystem.Exists('intl_tab_anarchist'), GetVariableSystem.Exists('intl_tab_mutualist')), GetVariableSystem.Exists('intl_tab_syndicalist')), GetVariableSystem.Exists('intl_tab_blanquist')), GetVariableSystem.Exists('intl_tab_marxist'))), GetGlobalVariable('intl_vote_active').IsSet)]"
		size = { 410 5 }
		position = { 15 785 }
		alpha = 0.70
		parentanchor = top|hcenter
		blockoverride "values" {
			value = "[GetGlobalVariable('intl_vote_months_left').GetValue]"
			min = 0
			max = 6
		}
	}

	### CLOSE BUTTON â€” rendered after vbox so it sits on top
	close_button = {
		parentanchor = right|top
		position = { -8 8 }
		onclick = "[GetVariableSystem.Clear('internationale_open')]"
		shortcut = "close_window"
	}
}

types internationale_gui_types {

	### FACTION TAB BUTTON
	### Two overlapping buttons handle the toggle: one for active state, one for inactive.
	type intl_tab_button = widget {
		layoutpolicy_horizontal = expanding
		size = { 0 30 }

		button = {
			size = { 100% 100% }
			using = default_button_primary
			enabled = no
			block "tab_text" { text = "" }
			using = fontsize_medium
			align = hcenter|nobaseline
			block "tab_active_visible" { visible = no }
			block "tab_onclick_clear" { onclick = "" }
		}

		button = {
			size = { 100% 100% }
			using = default_button
			block "tab_text" { text = "" }
			using = fontsize_medium
			align = hcenter|nobaseline
			block "tab_inactive_visible" { visible = yes }
			block "tab_onclick_set" { onclick = "" }
		}
	}

	### FACTION DELEGATE CARD
	type intl_faction_card = widget {
		layoutpolicy_horizontal = expanding
		size = { 0 118 }

		# Active state button (shown when selected, click to deselect)
		button = {
			size = { 100% 100% }
			using = default_button
			enabled = no
			block "card_active_visible" { visible = no }
			block "card_onclick_clear" { onclick = "" }
		}

		# Inactive state button (shown when not selected, click to select)
		button = {
			size = { 100% 100% }
			using = default_button
			block "card_inactive_visible" { visible = yes }
			block "card_onclick_set" { onclick = "" }
		}

		# Portrait â€” absolutely positioned top-right, does not affect text layout
		widget = {
			size = { 60 68 }
			parentanchor = top|right
			position = { -4 4 }
			using = not_clickthrough

			block "card_portrait" {
				icon = {
					size = { 28 28 }
					parentanchor = center
					texture = "gfx/interface/icons/generic_icons/identity_overlay.dds"
					block "card_color" { color = { 1 1 1 1 } }
				}
			}
		}

		vbox = {
			layoutpolicy_horizontal = expanding
			parentanchor = vcenter|hcenter
			spacing = 0
			margin = { 6 0 6 68 }

			textbox = {
				layoutpolicy_horizontal = expanding
				autoresize = yes
				align = hcenter|nobaseline
				using = fontsize_large
				block "card_delegate" { text = "" }
			}

			textbox = {
				layoutpolicy_horizontal = expanding
				autoresize = yes
				align = hcenter|nobaseline
				using = fontsize_small
				alpha = 0.55
				block "card_role" { text = "" }
			}
		}
	}

	### FACTION DETAIL PANEL
	type intl_faction_detail_panel = widget {
		layoutpolicy_horizontal = expanding
		minimumsize = { 0 80 }
		parentanchor = right

		background = {
			using = entry_bg_fancy
		}

		hbox = {
			layoutpolicy_horizontal = expanding
			spacing = 12
			
			margin = { 0 10 }

			# Character portrait â€” overridden per instance with correct datacontext
			block "detail_portrait" {
				widget = { size = { 0 1 } }
			}

			icon = {
				size = { 32 32 }
				parentanchor = vcenter
				texture = "gfx/interface/icons/generic_icons/identity_overlay.dds"
				block "detail_color" { color = { 1 1 1 1 } }
			}

		widget = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding

			vbox = {
				layoutpolicy_horizontal = expanding
				spacing = 5
				margin_top = -240
				

				textbox = {
					autoresize = yes
					using = fontsize_large
					parentanchor = left
					alwaystransparent = yes
					block "detail_faction_name" { text = "" }
				}

				textbox = {
					layoutpolicy_horizontal = expanding
					autoresize = yes
					using = fontsize_small
					align = left|nobaseline
					alpha = 0.6
					alwaystransparent = yes
					block "detail_title" { text = "" }
				}

				textbox = {
					margin_top = -240
					layoutpolicy_horizontal = expanding
					multiline = yes
					autoresize = yes
					using = fontsize_small
					align = left|nobaseline
					alpha = 0.6
					alwaystransparent = yes
					block "detail_desc" { text = "" }
				}
			}

			flowcontainer = {
				parentanchor = bottom|left
				position = { -35 0 }
				direction = horizontal
				spacing = 5
				margin = { 0 6 }

				block "detail_laws" {}
			}
		}
		}
	}

	### FACTION LEGEND (kept for reference/backwards compatibility)
	type intl_faction_legend = hbox {
		spacing = 5

		icon = {
			size = { 14 14 }
			parentanchor = vcenter
			texture = "gfx/interface/icons/generic_icons/identity_overlay.dds"
			block "legend_color" {
				color = { 1 1 1 1 }
			}
		}

		textbox = {
			autoresize = yes
			parentanchor = vcenter
			align = nobaseline
			using = fontsize_medium
			block "legend_text" {
				text = ""
			}
		}
	}
}

