		### DETAIL SECTION (scrollable, expands to fill remaining space)
		scrollarea = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding

			minimumsize = { 0 90 }
			scrollbarpolicy_horizontal = always_off

			background = {
						texture = "gfx/interface/backgrounds/internationale2.png"
						size = { 90% 90% }
						margin_left = -10
						alpha = 0.2
						margin_right = -10
						margin_top = 10
						
					}

			scrollwidget = {
				flowcontainer = {
					parentanchor = left|top
					direction = vertical
					layoutpolicy_horizontal = expanding
					spacing = 4
					margin = { 8 6 }

					### CURRENT MOTION â€” no active vote
					widget = {
						layoutpolicy_horizontal = expanding
						size = { 0 180 }
						visible = "[And(Not(Or(Or(Or(Or(GetVariableSystem.Exists('intl_tab_anarchist'), GetVariableSystem.Exists('intl_tab_mutualist')), GetVariableSystem.Exists('intl_tab_syndicalist')), GetVariableSystem.Exists('intl_tab_blanquist')), GetVariableSystem.Exists('intl_tab_marxist'))), Not(GetGlobalVariable('intl_vote_active').IsSet))]"

						background = {
							using = entry_bg_fancy
							alpha = 0.3
						}

						vbox = {
							parentanchor = center
							spacing = 8
							textbox = {
								size = { 700 40 }
								text = "intl_no_current_motion"
								using = fontsize_large
								align = hcenter|nobaseline
								parentanchor = hcenter
								alpha = 0.6
							}
							textbox = {
								size = { 700 30 }
								text = "intl_no_current_motion_hint"
								using = fontsize_small
								align = hcenter|nobaseline
								parentanchor = hcenter
								alpha = 0.4
							}
						}
					}

					### CURRENT MOTION â€” active vote interface
					widget = {
						size = { 100% 360 }
						visible = "[And(Not(Or(Or(Or(Or(GetVariableSystem.Exists('intl_tab_anarchist'), GetVariableSystem.Exists('intl_tab_mutualist')), GetVariableSystem.Exists('intl_tab_syndicalist')), GetVariableSystem.Exists('intl_tab_blanquist')), GetVariableSystem.Exists('intl_tab_marxist'))), GetGlobalVariable('intl_vote_active').IsSet)]"
						

						hbox = {
							size = { 100% 360 }

							### LEFT CONTAINER
							hbox = {
								size = { 50% 360 }
								widget = {
									size = { 270 360 }
									character_portrait_front_vs_left = { visible = "[GetGlobalVariable('intl_vote_current_faction_anarchist').IsSet]" datacontext = "[GetPlayer.MakeScope.Var('bakunin_scope_gui').GetCharacter]" blockoverride "portrait_icons" {} blockoverride "portrait_button_onclick" { onclick = "" } blockoverride "portrait_button_onrightclick" { onrightclick = "" } }
									character_portrait_front_vs_left = { visible = "[GetGlobalVariable('intl_vote_current_faction_mutualist').IsSet]" datacontext = "[GetPlayer.MakeScope.Var('proudhon_scope_gui').GetCharacter]" blockoverride "portrait_icons" {} blockoverride "portrait_button_onclick" { onclick = "" } blockoverride "portrait_button_onrightclick" { onrightclick = "" } }
									character_portrait_front_vs_left = { visible = "[GetGlobalVariable('intl_vote_current_faction_syndicalist').IsSet]" datacontext = "[GetPlayer.MakeScope.Var('bel_de_paepe_scope_gui').GetCharacter]" blockoverride "portrait_icons" {} blockoverride "portrait_button_onclick" { onclick = "" } blockoverride "portrait_button_onrightclick" { onrightclick = "" } }
									character_portrait_front_vs_left = { visible = "[GetGlobalVariable('intl_vote_current_faction_blanquist').IsSet]" datacontext = "[GetPlayer.MakeScope.Var('blanqui_scope_gui').GetCharacter]" blockoverride "portrait_icons" {} blockoverride "portrait_button_onclick" { onclick = "" } blockoverride "portrait_button_onrightclick" { onrightclick = "" } }
									character_portrait_front_vs_left = { visible = "[GetGlobalVariable('intl_vote_current_faction_marxist').IsSet]" datacontext = "[GetPlayer.MakeScope.Var('karl_marx_scope_gui').GetCharacter]" blockoverride "portrait_icons" {} blockoverride "portrait_button_onclick" { onclick = "" } blockoverride "portrait_button_onrightclick" { onrightclick = "" } }
								}
								widget = {
									layoutpolicy_horizontal = expanding
									size = { 0 360 }

									background = { using = entry_bg_fancy alpha = 0.35 }
									### TEXT container
									vbox = {
										layoutpolicy_horizontal = expanding
										spacing = 6
										margin = { -250 10 }
										position = { 0 -10 }						
										textbox = { layoutpolicy_horizontal = expanding size = { 0 46 } text = "intl_lawname_anarchist_council_republic" using = fontsize_large align = left|nobaseline visible = "[GetGlobalVariable('intl_vote_current_law_anarchist_council_republic').IsSet]" }
										textbox = { layoutpolicy_horizontal = expanding size = { 0 46 } text = "intl_lawname_marxist_council_republic" using = fontsize_large align = left|nobaseline visible = "[GetGlobalVariable('intl_vote_current_law_marxist_council_republic').IsSet]" }
										textbox = { layoutpolicy_horizontal = expanding size = { 0 46 } text = "intl_lawname_mutualist_economy" using = fontsize_large align = left|nobaseline visible = "[GetGlobalVariable('intl_vote_current_law_mutualist_economy').IsSet]" }
